Initial Grayscale submission with Triton kernel.
Y = 0.2989 R + 0.5870 G + 0.1140 B
"""

import torch
import triton
import triton.language as tl


@triton.jit
def grayscale_kernel(
    rgb_ptr, out_ptr,
    n_pixels,
    BLOCK_SIZE: tl.constexpr,
    EVEN: tl.constexpr,
):
    """RGB->gray with coalesced de-interleaved loads + fma.

    Each program processes BLOCK_SIZE pixels via three coalesced strided
    loads (no div/mod). On the EVEN fast-path (n_pixels divisible by
    BLOCK_SIZE, always true for square power-of-two inputs) all masking is
    dropped to cut transaction/compare overhead. fma fuses the weight chain.
    """
    pid = tl.program_id(0)
    block_start = pid * BLOCK_SIZE
    offsets = block_start + tl.arange(0, BLOCK_SIZE)
    # Contiguous deinterleave: load a flat 3*BLOCK_SIZE chunk in one coalesced
    # pass, then reshape to (BLOCK_SIZE, 3) to split channels in registers.
    flat = block_start * 3 + tl.arange(0, BLOCK_SIZE * 3)
    if EVEN:
        vals = tl.load(rgb_ptr + flat)
        vals = tl.reshape(vals, (BLOCK_SIZE, 3))
        r = vals[:, 0]
        g = vals[:, 1]
        b = vals[:, 2]
        gray = tl.fma(0.2989, r, tl.fma(0.5870, g, 0.1140 * b))
        tl.store(out_ptr + offsets, gray)
    else:
        mask3 = flat < n_pixels * 3
        vals = tl.load(rgb_ptr + flat, mask=mask3, other=0.0)
        vals = tl.reshape(vals, (BLOCK_SIZE, 3))
        r = vals[:, 0]
        g = vals[:, 1]
        b = vals[:, 2]
        gray = tl.fma(0.2989, r, tl.fma(0.5870, g, 0.1140 * b))
        mask = offsets < n_pixels
        tl.store(out_ptr + offsets, gray, mask=mask)


def custom_kernel(data):
    """RGB->grayscale using flat contiguous loads for maximal coalescing.

    Uses a larger BLOCK_SIZE and tuned warp/stage counts to saturate
    H100 memory bandwidth for the bandwidth-bound conversion.
    """
    rgb, output = data
    H, W, C = rgb.shape
    rgb = rgb.contiguous()
    n_pixels = H * W
    # Size-adaptive block: large images use bigger blocks to cut launch
    # overhead and keep the HBM pipeline saturated; smaller images keep
    # moderate blocks for occupancy.
    if n_pixels >= (4096 * 4096):
        BLOCK_SIZE = 8192
        nw, ns = 8, 4
    elif n_pixels >= (2048 * 2048):
        BLOCK_SIZE = 8192
        nw, ns = 8, 4
    else:
        BLOCK_SIZE = 4096
        nw, ns = 8, 4
    even = (n_pixels % BLOCK_SIZE) == 0
    grid = (triton.cdiv(n_pixels, BLOCK_SIZE),)
    grayscale_kernel[grid](
        rgb, output, n_pixels,
        BLOCK_SIZE=BLOCK_SIZE,
        EVEN=even,
        num_warps=nw,
        num_stages=ns,
    )
    return output
# EVOLVE-BLOCK-END

