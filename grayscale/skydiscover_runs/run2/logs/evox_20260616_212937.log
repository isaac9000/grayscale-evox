    """RGB->grayscale using flat contiguous loads for maximal coalescing.

    Uses a larger BLOCK_SIZE and tuned warp/stage counts to saturate
    H100 memory bandwidth for the bandwidth-bound conversion.
    """
    rgb, output = data
    H, W, C = rgb.shape
    rgb = rgb.contiguous()
    n_pixels = H * W
    # Size-adaptive block: large images use bigger blocks to cut launch
    # overhead and keep the HBM pipeline saturated; smaller images keep
    # moderate blocks for occupancy.
    if n_pixels >= (4096 * 4096):
        BLOCK_SIZE = 8192
        nw, ns = 8, 4
    elif n_pixels >= (2048 * 2048):
        BLOCK_SIZE = 8192
        nw, ns = 8, 4
    else:
        BLOCK_SIZE = 4096
        nw, ns = 8, 4
    even = (n_pixels % BLOCK_SIZE) == 0
    grid = (triton.cdiv(n_pixels, BLOCK_SIZE),)
    grayscale_kernel[grid](
        rgb, output, n_pixels,
        BLOCK_SIZE=BLOCK_SIZE,
        EVEN=even,
        num_warps=nw,
        num_stages=ns,
    )
